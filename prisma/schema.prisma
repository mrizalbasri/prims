generator client {
  provider   = "prisma-client-js"
  
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER MANAGEMENT
// ============================================

enum UserRole {
  STUDENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String     @map("password_hash")
  role            UserRole   @default(STUDENT)
  fullName        String     @map("full_name")
  major           String?
  cohort          String?
  status          UserStatus @default(ACTIVE)
  hasModuleAccess Boolean    @default(false) @map("has_module_access")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  testAttempts       TestAttempt[]
  auditLogs          AuditLog[]
  vocabularyProgress VocabularyProgress[]
  vocabularySessions VocabularySession[]
  writingSubmissions WritingResponse[]
  speakingSessions   SpeakingResponse[]
  reminderPreference ReminderPreference?
  reminderLogs       ReminderLog[]
  learningSessions   LearningSession[]
  finalResults       FinalResult[]

  @@map("users")
}

// ============================================
// PLACEMENT TEST
// ============================================

enum TestAttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  PROCESSING
  COMPLETED
  FAILED
}

model TestAttempt {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  status      TestAttemptStatus @default(NOT_STARTED)
  startedAt   DateTime?         @map("started_at")
  submittedAt DateTime?         @map("submitted_at")
  completedAt DateTime?         @map("completed_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionAttempts SectionAttempt[]
  finalResult     FinalResult?

  @@index([userId])
  @@index([status])
  @@map("test_attempts")
}

enum SectionType {
  VOCABULARY
  GRAMMAR
  READING
  WRITING
  SPEAKING
}

enum SectionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  TIMED_OUT
}

model SectionAttempt {
  id            String        @id @default(cuid())
  testAttemptId String        @map("test_attempt_id")
  sectionType   SectionType   @map("section_type")
  status        SectionStatus @default(NOT_STARTED)
  startTime     DateTime?     @map("start_time")
  endTime       DateTime?     @map("end_time")
  rawScore      Float         @default(0) @map("raw_score")
  weightedScore Float         @default(0) @map("weighted_score")
  feedback      String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  testAttempt      TestAttempt       @relation(fields: [testAttemptId], references: [id], onDelete: Cascade)
  objectiveAnswers ObjectiveAnswer[]
  writingResponse  WritingResponse?
  speakingResponse SpeakingResponse?

  @@unique([testAttemptId, sectionType])
  @@map("section_attempts")
}

// ============================================
// QUESTIONS & ANSWERS
// ============================================

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model Question {
  id           String             @id @default(cuid())
  sectionType  SectionType        @map("section_type")
  difficulty   QuestionDifficulty
  questionText String             @map("question_text")
  options      String[]           @default([])
  correctAnswer String             @map("correct_answer")
  explanation  String?
  metadata     Json?
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([sectionType, difficulty])
  @@map("questions")
}

model ObjectiveAnswer {
  id               String   @id @default(cuid())
  sectionAttemptId String   @map("section_attempt_id")
  questionId       String   @map("question_id")
  selectedOption   String   @map("selected_option")
  isCorrect        Boolean  @map("is_correct")
  score            Float    @default(0)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  sectionAttempt SectionAttempt @relation(fields: [sectionAttemptId], references: [id], onDelete: Cascade)

  @@unique([sectionAttemptId, questionId])
  @@index([sectionAttemptId])
  @@index([questionId])
  @@map("objective_answers")
}

// ============================================
// WRITING SECTION
// ============================================

enum WritingPromptType {
  PARAGRAPH
  ESSAY
}

model WritingPrompt {
  id         String             @id @default(cuid())
  type       WritingPromptType
  level      ProficiencyLevel?
  promptText String             @map("prompt_text")
  rubric     Json?
  isActive   Boolean            @default(true) @map("is_active")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  @@map("writing_prompts")
}

model WritingResponse {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  sectionAttemptId String   @unique @map("section_attempt_id")
  content          String
  wordCount        Int      @default(0) @map("word_count")
  feedback         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionAttempt SectionAttempt @relation(fields: [sectionAttemptId], references: [id], onDelete: Cascade)

  @@map("writing_responses")
}

// ============================================
// SPEAKING SECTION
// ============================================

enum SpeakingScenarioType {
  DAILY_CONVERSATION
  ACADEMIC_DISCUSSION
  PRESENTATION
}

model SpeakingScenario {
  id           String               @id @default(cuid())
  type         SpeakingScenarioType
  level        ProficiencyLevel?
  title        String
  description  String
  promptText   String               @map("prompt_text")
  initialAudio String?              @map("initial_audio")
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@map("speaking_scenarios")
}

model SpeakingResponse {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  sectionAttemptId String   @unique @map("section_attempt_id")
  audioUrl         String?  @map("audio_url")
  transcript       String?
  feedback         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionAttempt SectionAttempt @relation(fields: [sectionAttemptId], references: [id], onDelete: Cascade)

  @@map("speaking_responses")
}

// ============================================
// VOCABULARY MODULE
// ============================================

enum VocabularyCategory {
  ACADEMIC
  BUSINESS
  GENERAL
  TECHNICAL
}

model VocabularyCard {
  id              String             @id @default(cuid())
  term            String
  meaning         String
  exampleSentence String?            @map("example_sentence")
  pronunciation   String?
  audioUrl        String?            @map("audio_url")
  category        VocabularyCategory @default(GENERAL)
  difficulty      QuestionDifficulty @default(MEDIUM)
  metadata        Json?
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  // Relations
  progress VocabularyProgress[]

  @@index([category, difficulty])
  @@map("vocabulary_cards")
}

enum CardState {
  NEW
  LEARNING
  REVIEW
  MASTERED
}

model VocabularyProgress {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  cardId          String    @map("card_id")
  state           CardState @default(NEW)
  repetitionCount Int       @default(0) @map("repetition_count")
  lastReviewedAt  DateTime? @map("last_reviewed_at")
  masteredAt      DateTime? @map("mastered_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  card VocabularyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId])
  @@index([state])
  @@map("vocabulary_progress")
}

model VocabularySession {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  cardsReviewed Int       @default(0) @map("cards_reviewed")
  cardsLearned  Int       @default(0) @map("cards_learned")
  cardsMastered Int       @default(0) @map("cards_mastered")
  durationSec   Int       @default(0) @map("duration_sec")
  startedAt     DateTime  @map("started_at")
  endedAt       DateTime? @map("ended_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("vocabulary_sessions")
}

// ============================================
// RESULTS & AUDIT
// ============================================

enum ProficiencyLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  PROFICIENT
}

model FinalResult {
  id            String           @id @default(cuid())
  testAttemptId String           @unique @map("test_attempt_id")
  userId        String           @map("user_id")
  overallLevel  ProficiencyLevel @map("overall_level")
  overallScore  Float            @map("overall_score")
  cefrLevel     String           @map("cefr_level")
  sectionScores Json             @map("section_scores")
  recommendation String?
  createdAt     DateTime         @default(now()) @map("created_at")

  // Relations
  testAttempt TestAttempt @relation(fields: [testAttemptId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("final_results")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  resource  String
  metadata  Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("audit_logs")
}

// ============================================
// MISC (LEARNING, REMINDERS)
// ============================================

enum ReminderCadence {
  DAILY
  WEEKLY
  OFF
}

enum ReminderChannel {
  EMAIL
  PUSH
  BOTH
}

model ReminderPreference {
  id        String          @id @default(cuid())
  userId    String          @unique @map("user_id")
  cadence   ReminderCadence @default(DAILY)
  channel   ReminderChannel @default(EMAIL)
  timeOfDay String          @default("09:00") @map("time_of_day")
  isActive  Boolean         @default(true) @map("is_active")
  updatedAt DateTime        @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reminder_preferences")
}

model ReminderLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  sentAt    DateTime @default(now()) @map("sent_at")
  channel   String
  status    String

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reminder_logs")
}

model LearningSession {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  sectionType String   @map("section_type")
  durationSec Int      @map("duration_sec")
  completedAt DateTime @default(now()) @map("completed_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("learning_sessions")
}

enum ResponseStatus {
  SUCCESS
  ERROR
}
