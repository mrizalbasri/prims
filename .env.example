# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://postgres:postgres@localhost:5433/prism?schema=public"

PRISMA_CLIENT_ENGINE_TYPE="library"

# AI Services (Google Gemini)
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_WRITING_MODEL="gemini-2.5-flash"
GEMINI_SPEAKING_MODEL="gemini-2.5-flash-native-audio-dialog"

# AI Services (MiniMax via TokenRouter)
MINIMAX_API_KEY="your-minimax-api-key-here"
MINIMAX_MODEL="MiniMax-M3"
MINIMAX_BASE_URL="https://api.tokenrouter.com/v1"

# Active LLM Provider: "gemini" or "minimax"
LLM_PROVIDER="minimax"

# JWT Secret for Auth
JWT_SECRET="your-jwt-secret-here"
